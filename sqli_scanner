def print_report(all_findings, url, start_time, request_count):
    elapsed   = time.time() - start_time
    confirmed = all_findings

    print("\n")
    print("  ====================================================")
    print("                     SCAN RESULTS")
    print("  ====================================================")
    print(f"  Target      : {url}")
    print(f"  Finished    : {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}")
    print(f"  Duration    : {elapsed:.1f}s")
    print(f"  Requests    : {request_count[0]}")
    print(f"  Confirmed   : {len(confirmed)} finding(s) [Verified / 0 False Positives]")
    print("  ====================================================")

    if not confirmed:
        print()
        print("  Nothing found. Some things to check:")
        print()
        print("  1. Session cookie - run with --debug to see what the scanner")
        print("     is actually receiving. If it looks like a login page,")
        print('     add --cookies "session=<value>"')
        print()
        print("  2. Payload depth - try --level 2 or --level 3")
        print()
        print("  3. Use --debug to see the raw baseline response")
        print()
        return

    print(f"\n  [!] CONFIRMED VULNERABILITIES ({len(confirmed)})\n")
    for i, f in enumerate(confirmed, 1):
        print(f"  {i}. {f['type'].upper()}")
        print(f"     Parameter : {f['param']}")
        print(f"     Database  : {f['db']}")
        print(f"     Payload   : {f['payload']}")
        print(f"     Note      : {f['note']}")
        print()

    print("  ====================================================")
    print("  HOW TO FIX THIS (for developers):")
    print()
    print("  The root cause is almost always the same thing -")
    print("  user input being pasted directly into a SQL query.")
    print()
    print("  Bad:   \"SELECT * FROM users WHERE id = \" + user_input")
    print("  Good:  use prepared statements / parameterized queries")
    print()
    print("  Python:  cursor.execute('SELECT * FROM users WHERE id = %s', (id,))")
    print("  PHP:     $stmt = $pdo->prepare('SELECT * FROM users WHERE id = ?')")
    print("           $stmt->execute([$id]);")
    print("  Node:    db.query('SELECT * FROM users WHERE id = ?', [id])")
    print("  ====================================================\n")


def save_report(all_findings, url, path):
    try:
        with open(path, "w") as f:
            f.write("SQL Injection Scan Report\n")
            f.write(f"Target: {url}\n")
            f.write(f"Date:   {datetime.now()}\n")
            f.write("=" * 60 + "\n\n")
            if not all_findings:
                f.write("No findings.\n")
            else:
                for finding in all_findings:
                    f.write(f"Type      : {finding['type']}\n")
                    f.write(f"Parameter : {finding['param']}\n")
                    f.write(f"Database  : {finding['db']}\n")
                    f.write(f"Payload   : {finding['payload']}\n")
                    f.write(f"Note      : {finding['note']}\n")
                    f.write("-" * 40 + "\n")
        print(f"\n  Report saved to: {path}")
    except Exception as e:
        print(f"\n  Couldn't save report: {e}")


