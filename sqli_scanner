# Strings that tell us we hit a login page instead of the real app.
# If the baseline response contains any of these, we warn the user immediately.
LOGIN_PAGE_HINTS = [
    "login",
    "sign in",
    "please log in",
    "password",
    "username",
    "authentication required",
    "session expired",
    "location: /login",
]


