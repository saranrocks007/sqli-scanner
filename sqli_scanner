    ("' UNION SELECT 'SQLiVRY'#", 2, "union_verify", "Verified UNION (1 column)"),
    ("' UNION SELECT 'SQLiVRY','SQLiVRY'#", 2, "union_verify", "Verified UNION (2 columns)"),
