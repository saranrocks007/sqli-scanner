def send_request(session, url, method, post_data, timeout):
    """
    Send a single HTTP request. Returns (response, elapsed_seconds).
    Returns (None, 0) if something goes wrong.
    """
    try:
        start = time.time()
        if method == "POST":
            resp = session.post(url, data=post_data, timeout=timeout, allow_redirects=True)
        else:
            resp = session.get(url, timeout=timeout, allow_redirects=True)
        elapsed = time.time() - start
        return resp, elapsed
    except requests.exceptions.Timeout:
        # A timeout on a time-based payload might itself be a signal
        return None, timeout
    except Exception as e:
        log(f"Request failed: {e}", tag="ERR")
        return None, 0


def debug_baseline(resp, url, args):
    """
    When --debug is on, print a snapshot of the baseline response so the
    user can see exactly what the scanner is working with.
    This is the fastest way to diagnose a session / cookie problem.
    """
    if not args.debug:
        return

    print()
    print("  -- DEBUG: baseline response snapshot --------------")
    print(f"  Final URL    : {resp.url}")
    print(f"  Status code  : {resp.status_code}")
    print(f"  Content-Type : {resp.headers.get('Content-Type', 'unknown')}")
    print(f"  Body length  : {len(resp.text)} bytes")
    print()
    print("  First 600 chars of response body:")
    print("  " + "-" * 50)
    snippet = resp.text[:600].replace("\n", "\n  ")
    print(f"  {snippet}")
    print("  " + "-" * 50)
    print()


def scan_one_param(url, param, method, post_data, session, args):
    """
    Test a single parameter for SQL injection.

    The basic idea:
    1. Send a normal request first to record what the page looks like.
    2. Check immediately if we got a login page - if so, stop and warn.
    3. Send each payload one at a time.
    4. Compare - did we get a DB error? Did it take longer? Did content change?
    5. Collect and return all findings.
    """
    findings = []

    log_info(f"Testing param '{param}' ({method})")

    # Step 1: baseline - what does a normal response look like?
    baseline_resp, baseline_time = send_request(session, url, method, post_data, args.timeout)
    if baseline_resp is None:
        log(f"Couldn't reach {url} - check the URL and try again", tag="ERR")
        return findings

    baseline_len = len(baseline_resp.text)

    # Step 2: show the baseline if --debug is on
    debug_baseline(baseline_resp, url, args)

    # Step 3: check if we landed on a login page instead of the real app
    if looks_like_login_page(baseline_resp.text, baseline_resp.url):
        print()
        log_warn("=" * 55)
        log_warn("SESSION PROBLEM DETECTED")
        log_warn("The baseline response looks like a login page.")
        log_warn("The scanner is not reaching the actual target.")
        log_warn("")
        log_warn("How to fix this:")
        log_warn("  1. Log into the target in your browser")
        log_warn("  2. Open DevTools (F12) -> Application/Storage -> Cookies")
        log_warn("  3. Copy your session cookie value")
        log_warn("  4. Re-run with:")
        log_warn('     --cookies "session=<your-value>"')
        log_warn("")
        log_warn("  Use --debug to see the full baseline response")
        log_warn("=" * 55)
        print()
        return findings

    log_debug(f"Baseline OK: status={baseline_resp.status_code}, "
              f"len={baseline_len}B, time={baseline_time:.2f}s", args.verbose)

    # Step 4: try each payload
    payloads_to_try = [(p, lvl, cat, desc) for p, lvl, cat, desc in PAYLOADS if lvl <= args.level]
    total = len(payloads_to_try)

    for i, (payload, level, category, description) in enumerate(payloads_to_try, 1):

        # Small pause between requests so we don't hammer the server
        time.sleep(1.0 / args.rate)

        # Build the request with payload injected
        if method == "GET":
            injected_url = inject_into_url(url, param, payload)
            resp, elapsed = send_request(session, injected_url, "GET", None, args.timeout)
        else:
            data = dict(post_data or {})
            data[param] = payload
            resp, elapsed = send_request(session, url, "POST", data, args.timeout)

        if resp is None:
            log_debug(f"[{i}/{total}] No response for: {payload[:40]}", args.verbose)
            continue

        log_debug(
            f"[{i}/{total}] '{payload[:35]}' -> "
            f"status={resp.status_code} len={len(resp.text)}B time={elapsed:.2f}s",
            args.verbose
        )

        # If this response also looks like a login page, the session probably
        # just expired mid-scan. No point continuing.
        if looks_like_login_page(resp.text, resp.url):
            log_warn("Session expired mid-scan. Re-run with a fresh cookie.")
            break

        # --- Detection check 1: DB error in the response body ---
        # This is the most reliable signal. The database is complaining out loud.
        error_found, db_type = check_for_db_error(resp.text)
        if error_found:
            log_vuln(f"DB error ({db_type}) | param='{param}' | payload: {payload}")
            findings.append({
                "type":        "error-based",
                "db":          db_type,
                "param":       param,
                "payload":     payload,
                "description": description,
                "note":        f"Response contained a {db_type} error message",
            })
            continue

        # --- Detection check 2: time-based blind ---
        # The database slept, so the HTTP response was slow.
        if category == "time" and is_slow(elapsed, baseline_time):
            log_vuln(
                f"Time delay {elapsed:.1f}s (baseline {baseline_time:.1f}s) "
                f"| param='{param}' | payload: {payload}"
            )
            findings.append({
                "type":        "time-based blind",
                "db":          "unknown (confirm manually)",
                "param":       param,
                "payload":     payload,
                "description": description,
                "note":        f"Response took {elapsed:.1f}s vs baseline {baseline_time:.1f}s",
            })
            continue

        # --- Detection check 5: Verified UNION Reflection ---
        if category == "union_verify" and "SQLiVRY" in resp.text:
            log_vuln(f"Confirmed UNION SQLi | param='{param}' | payload: {payload}")
            findings.append({
                "type":        "union-based (verified)",
                "db":          "unknown",
                "param":       param,
                "payload":     payload,
                "description": description,
                "note":        "Injected string 'SQLiVRY' was successfully reflected via UNION SELECT.",
            })
            continue

        # We exclusively rely on DB errors and Time-based delays 
        # to guarantee 0% false positives strictly.

    return findings


