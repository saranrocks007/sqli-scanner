def log(msg, tag="*"):
    ts = datetime.now().strftime("%H:%M:%S")
    print(f"  [{ts}] [{tag}] {msg}")


def log_vuln(msg):  log(msg, tag="VULN")
def log_info(msg):  log(msg, tag=" + ")
def log_warn(msg):  log(msg, tag="WARN")
def log_debug(msg, verbose=False):
    if verbose:
        log(msg, tag="...")


def check_for_db_error(response_text):
    """
    Look through the response for any known DB error message.
    Returns (True, "MySQL") or (False, None).
    """
    lowered = response_text.lower()
    for db_name, patterns in DB_ERRORS.items():
        for pattern in patterns:
            if re.search(pattern, lowered):
                return True, db_name
    return False, None


def looks_like_login_page(response_text, response_url=""):
    """
    Returns True if the response looks like a login redirect.
    This is the #1 reason people get zero results - their session
    cookie expired or was never set.
    """
    lowered = response_text.lower()
    url_lower = response_url.lower()

    # Check URL for login indicators
    if "login" in url_lower:
        return True

    # Count how many login-page hints appear in the body
    hits = sum(1 for hint in LOGIN_PAGE_HINTS if hint in lowered)
    return hits >= 2


def is_slow(elapsed, baseline, expected_delay=5):
    """
    Returns True if the response took noticeably longer than usual.
    We use 70% of the expected delay as the threshold to account
    for network jitter.
    """
    return (elapsed - baseline) >= (expected_delay * 0.7)


def extract_params(url):
    """Pull parameter names out of a URL like ?id=1&name=foo -> ['id', 'name']"""
    qs = urlparse(url).query
    return list(parse_qs(qs).keys())


def inject_into_url(url, param, payload):
    """
    Replace one parameter's value with our payload and return the new URL.
    All other parameters are kept intact.
    """
    parsed = urlparse(url)
    params = parse_qs(parsed.query, keep_blank_values=True)
    params[param] = [payload]
    new_query = urlencode(params, doseq=True)
    return parsed._replace(query=new_query).geturl()


def build_session(cookies, user_agent, extra_headers):
    """Create a requests Session with our cookies and headers pre-loaded."""
    s = requests.Session()
    s.verify = False

    s.headers.update({
        "User-Agent": user_agent or (
            "Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 "
            "(KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36"
        ),
        "Accept": "text/html,application/xhtml+xml,*/*",
        "Accept-Language": "en-US,en;q=0.9",
        "Connection": "keep-alive",
    })

    # Parse cookie string like "PHPSESSID=abc; security=low"
    if cookies:
        for chunk in cookies.split(";"):
            chunk = chunk.strip()
            if "=" in chunk:
                k, v = chunk.split("=", 1)
                s.cookies.set(k.strip(), v.strip())

    # Any extra headers passed via --header "X-Foo: bar"
    if extra_headers:
        for h in extra_headers:
            if ":" in h:
                k, v = h.split(":", 1)
                s.headers[k.strip()] = v.strip()

    return s


