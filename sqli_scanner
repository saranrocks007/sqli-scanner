def main():
    parser = argparse.ArgumentParser(
        description="SQL Injection Scanner - for authorized testing only",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
examples:
  # Basic scan on an authenticated target
  python sqli_scanner.py -u "https://target.com/profile?id=1" --cookies "session=abc123"

  # If you get no results, run with --debug first to see what the scanner sees
  python sqli_scanner.py -u "https://target.com/profile?id=1" --cookies "session=abc123" --debug

  # Deeper scan (time-based blind) targeting an API
  python sqli_scanner.py -u "https://api.target.com/v1/user?id=1" --level 3 --out report.txt

  # POST login form
  python sqli_scanner.py -u "https://target.com/login" --method POST --data "user=admin&pass=test"

levels:
  1 = classic payloads only, fast (default)
  2 = + error-based and UNION probes
  3 = + time-based blind (slowest, most thorough)

getting your session cookie:
  1. Open the target website in your browser and log in
  2. Press F12 -> Application/Storage tab -> Cookies
  3. Copy your session cookie value
  4. Pass it as: --cookies "session=<paste here>"
        """,
    )

    parser.add_argument("-u", "--url",     required=True,   help="Target URL (include params: ?id=1)")
    parser.add_argument("--method",        default="GET",   help="GET or POST (default: GET)")
    parser.add_argument("--data",          default=None,    help="POST body: 'user=admin&pass=x'")
    parser.add_argument("--cookies",       default=None,    help="Cookies: 'PHPSESSID=abc;security=low'")
    parser.add_argument("--header",        action="append", help="Extra header (repeatable): 'X-Foo: bar'")
    parser.add_argument("--user-agent",    default=None,    help="Custom User-Agent string")
    parser.add_argument("--level",         type=int, default=1, choices=[1, 2, 3],
                        help="Payload depth: 1=basic 2=medium 3=full (default: 1)")
    parser.add_argument("--threads",       type=int, default=1,
                        help="How many params to test in parallel (default: 1)")
    parser.add_argument("--rate",          type=float, default=2.0,
                        help="Max requests per second (default: 2.0)")
    parser.add_argument("--timeout",       type=int, default=10,
                        help="Request timeout in seconds (default: 10)")
    parser.add_argument("--out",           default=None,    help="Save report to this file")
    parser.add_argument("-v", "--verbose", action="store_true", help="Show every request")
    parser.add_argument("--debug",         action="store_true",
                        help="Print the raw baseline response - use this when you get no results")

    args = parser.parse_args()

    print_banner()

    if not args.url.startswith(("http://", "https://")):
        print("  Error: URL must start with http:// or https://")
        sys.exit(1)

    method = args.method.upper()

    # Parse POST data string into a dict
    post_data = {}
    if args.data:
        for chunk in args.data.split("&"):
            if "=" in chunk:
                k, v = chunk.split("=", 1)
                post_data[k] = v

    # Authorization check
    print("  Before we start: only scan systems you own or have")
    print("  explicit written permission to test.")
    print()
    
    if sys.stdin.isatty():
        answer = input("  Do you have authorization to test this target? [yes/no]: ").strip().lower()
        if answer not in ("yes", "y"):
            print("\n  OK, stopping. Stay legal out there.\n")
            sys.exit(0)
    else:
        print("  [Auto-accepted authorization in non-interactive mode]")

    print()

    log_info(f"Target  : {args.url}")
    log_info(f"Method  : {method}")
    log_info(f"Level   : {args.level} ({'basic' if args.level == 1 else 'medium' if args.level == 2 else 'full'})")
    log_info(f"Payloads: {len([p for p in PAYLOADS if p[1] <= args.level])}")
    log_info(f"Rate    : {args.rate} req/s  |  Timeout: {args.timeout}s")

    if args.debug:
        log_info("Debug mode ON - will print baseline response")

    print()

    # Find what parameters to test
    if method == "GET":
        params = extract_params(args.url)
        if not params:
            print("  No parameters found in the URL.")
            print("  Make sure the URL includes something like ?id=1")
            sys.exit(1)
        log_info(f"Found params: {', '.join(params)}")
    else:
        params = list(post_data.keys())
        if not params:
            print("  POST method needs --data with at least one parameter.")
            sys.exit(1)
        log_info(f"POST params: {', '.join(params)}")

    print()

    # Build HTTP session
    session = build_session(args.cookies, getattr(args, "user_agent", None), args.header)

    # Count total requests made
    request_count = [0]
    original_send = session.request
    def counted_send(*a, **kw):
        request_count[0] += 1
        return original_send(*a, **kw)
    session.request = counted_send

    # Run
    start_time   = time.time()
    all_findings = []
    jobs = [(args.url, p, method, post_data, session, args) for p in params]

    if args.threads > 1 and len(jobs) > 1:
        with ThreadPoolExecutor(max_workers=args.threads) as pool:
            futures = {pool.submit(scan_one_param, *job): job for job in jobs}
            for future in as_completed(futures):
                try:
                    all_findings.extend(future.result())
                except Exception as e:
                    log(f"Thread error: {e}", tag="ERR")
    else:
        for job in jobs:
            all_findings.extend(scan_one_param(*job))

    print_report(all_findings, args.url, start_time, request_count)

    if args.out:
        save_report(all_findings, args.url, args.out)


if __name__ == "__main__":
    try:
        main()
    except KeyboardInterrupt:
        print("\n\n  Interrupted. Scan stopped.\n")
        sys.exit(0)
